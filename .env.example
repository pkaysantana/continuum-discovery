# OpenClaw Multi-Agent Biodefense Swarm Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# TELEGRAM CONFIGURATION (FLock.io SDG 3 Integration)
# =============================================================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat IDs (comma-separated for multiple subscribers)
TELEGRAM_CHAT_IDS=your_chat_id_here

# Optional: Telegram Bot Username
TELEGRAM_BOT_USERNAME=your_bot_username_here

# =============================================================================
# EXTERNAL API CONFIGURATIONS
# =============================================================================

# Planetary Computer API (for satellite data)
# Note: Currently using anonymous access, but you can register for increased limits
# PLANETARY_COMPUTER_API_KEY=your_pc_api_key_here

# ESMFold API Configuration (if using external service)
# ESMFOLD_API_URL=https://api.esmatlas.org
# ESMFOLD_API_KEY=your_esmfold_key_here

# Stripe Connect (for BiotechExecutiveAgent)
# STRIPE_API_KEY=your_stripe_key_here
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# =============================================================================
# SWARM CONFIGURATION
# =============================================================================

# Agent Monitoring Intervals (seconds)
EARTH_WATCHER_INTERVAL=300
BIO_SCIENTIST_INTERVAL=60
EXECUTIVE_INTERVAL=120
TELEGRAM_INTERVAL=180

# Unibase Memory Configuration
UNIBASE_MEMORY_PATH=./amina_results/unibase_memory/
UNIBASE_ENCRYPTION_KEY=auto_generated

# Emergency Contact Configuration
EMERGENCY_CONTACT_EMAIL=your_emergency_email@example.com
EMERGENCY_CONTACT_PHONE=+1234567890

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable/Disable Features
ENABLE_TELEGRAM=true
ENABLE_SATELLITE_MONITORING=true
ENABLE_PROTEIN_SYNTHESIS=true
ENABLE_COMMERCIAL_OPERATIONS=true

# =============================================================================
# EXAMPLE USAGE
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Run the swarm: python main_swarm.py
# 4. Monitor logs and agent communication
# =============================================================================
